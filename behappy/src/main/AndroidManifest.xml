<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TrueNASManager">

        <activity
            android:name="com.dmitrij.behappy.ui.SplashActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:enabled="true"
            android:theme="@style/Theme.TrueNASManager">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity-alias
            android:name="com.dmitrij.behappy.ui.FakeLauncher"
            android:enabled="false"
            android:exported="true"
            android:icon="@drawable/ic_notes_mask"
            android:label="@string/app_name_fake"
            android:targetActivity="com.dmitrij.behappy.ui.SplashActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity
            android:name="com.dmitrij.behappy.ui.SetupActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name="com.dmitrij.behappy.ui.MainActivity"
            android:exported="false"
            android:excludeFromRecents="true" />

        <activity
            android:name="com.dmitrij.behappy.ui.StatsDetailActivity"
            android:exported="false"
            android:excludeFromRecents="true" />

        <receiver
            android:name="com.dmitrij.behappy.widget.StatusWidget"
            android:exported="false"
            android:label="TrueNAS Status">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/status_widget_info" />
        </receiver>

        <receiver
            android:name="com.dmitrij.behappy.widget.CpuWidget"
            android:exported="false"
            android:label="TrueNAS CPU">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/cpu_widget_info" />
        </receiver>

        <receiver
            android:name="com.dmitrij.behappy.widget.RamWidget"
            android:exported="false"
            android:label="TrueNAS RAM">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/ram_widget_info" />
        </receiver>

    </application>

</manifest>
