<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:padding="12dp">

    <TextView
        android:id="@+id/widget_graph_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/stat_label"
        android:textColor="#80FFFFFF"
        android:textSize="11sp"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_graph_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_graph_title"
        android:text="0.0%"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/widget_graph_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/widget_graph_value"
        android:layout_marginTop="4dp"
        android:scaleType="fitXY"
        android:alpha="0.8" />

</RelativeLayout>
